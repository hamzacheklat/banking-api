## ⚡ Service d’update simplifié (Python)

```python
import psycopg2
import json
from datetime import datetime

def update_ecosystem_access(conn, product, action, region, environment, updates, user):
    """
    updates = {
        "database3": "open",
        "database5": "close"
    }
    """
    with conn.cursor() as cur:
        # 1. Récupérer la ligne existante
        cur.execute("""
            SELECT global_status, ecosystem_overrides
            FROM ecosystem_access
            WHERE product_name=%s AND action_name=%s AND region=%s AND environment=%s
        """, (product, action, region, environment))
        row = cur.fetchone()

        if not row:
            raise ValueError("La règle globale doit être créée avant les updates spécifiques.")

        global_status, overrides = row
        overrides = overrides or {}

        # 2. Appliquer les updates
        for ecosystem, new_status in updates.items():
            if new_status == global_status:
                overrides.pop(ecosystem, None)
            else:
                overrides[ecosystem] = new_status

        # 3. Sauvegarde UPSERT
        cur.execute("""
            UPDATE ecosystem_access
            SET ecosystem_overrides = %s,
                updated_at = %s,
                updated_by = %s
            WHERE product_name=%s AND action_name=%s AND region=%s AND environment=%s
        """, (json.dumps(overrides), datetime.utcnow(), user, product, action, region, environment))

    conn.commit()
```

