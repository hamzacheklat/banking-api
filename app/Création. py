### Service with type hints + docstrings

```python
from typing import Dict, Any


class ProductActionAvailableService(BaseService):
    def __init__(self, product_name: str) -> None:
        """
        Service layer for managing available product actions.

        Args:
            product_name (str): The name of the product to which the actions belong.
        """
        self.product_name = product_name

    def create(self, payload: Dict[str, Any]) -> Dict[str, Any]:
        """
        Create a new product action for the given product.

        Args:
            payload (Dict[str, Any]): Dictionary containing action details.
                Expected keys include:
                    - action_name (str): The name of the action to add.

        Returns:
            Dict[str, Any]: Serialized representation of the created action.

        Raises:
            ValueError: If the action already exists for this product.
        """
        existing = ProductActionAvailableModelController.filter_by_keys(
            product_name=self.product_name,
            action_name=payload.get("action_name"),
        )

        if existing:
            raise ValueError(
                f"Action '{payload.get('action_name')}' already exists "
                f"for product '{self.product_name}'"
            )

        instance_model = ProductActionAvailableModelController.create(
            product_name=self.product_name,
            **payload,
        )
        return ProductActionAvailableModelController.dump_instance(instance_model)
```

