Parfait ! Voici le **code complet** et propre pour :

* Rendre `replicatStatusRenderer` **générique** → renommé en `statusRenderer`.
* Pouvoir l’utiliser aussi dans la colonne `EXTRACTS`.
* Ajouter les **checkboxes sur les lignes groupées**.

---

## ✅ 1. **Composant `status-renderer.component.ts` (ancien `replicat-status-renderer.component.ts`)**

```ts
import { Component } from '@angular/core';
import { ICellRendererAngularComp } from 'ag-grid-community/angular';

@Component({
  selector: 'app-status-cell',
  template: `
    <div *ngIf="isGrouping">
      <span class="fa fa-circle" style="margin-left: 5px"
        [ngClass]="{
          'running': dataStatus === 'RUNNING',
          'stopped': dataStatus === 'STOPPED',
          'abended': dataStatus === 'ABENDED' || dataStatus === 'KILLED'
        }">
      </span>
      <span style="margin-left: 5px">{{ value }}</span>
    </div>
    <div *ngIf="!isGrouping">
      <span class="fa fa-circle" style="margin-left: 5px"
        [ngClass]="{
          'running': dataStatus === 'RUNNING',
          'stopped': dataStatus === 'STOPPED',
          'abended': dataStatus === 'ABENDED' || dataStatus === 'KILLED'
        }">
      </span>
    </div>
  `,
  styles: [
    `
      .running {
        color: #66AD25;
      }
      .stopped {
        color: #FF9723;
      }
      .abended {
        color: #CC333D;
      }
    `
  ]
})
export class StatusRendererComponent implements ICellRendererAngularComp {
  public value: string;
  public dataStatus: string;
  public isGrouping: boolean;
  public group: number;

  agInit(params: any): void {
    this.value = params.value;
    this.isGrouping = params.node.group;
    this.group = this.isGrouping ? params.node.childrenAfterFilter.length : null;

    // Prend le champ de statut dynamiquement depuis params
    if (params.data && params.status) {
      this.dataStatus = params.data[params.status];
    } else {
      this.dataStatus = this.getStatus(params);
    }
  }

  getStatus(params: any): string {
    let dataStatus = '';
    const statusField = params.status;

    if (!statusField) return dataStatus;

    params.node.allLeafChildren.forEach((child) => {
      const status = child.data[statusField];
      if (status === 'ABENDED') {
        dataStatus = 'ABENDED';
      } else if (status === 'STOPPED' && dataStatus !== 'ABENDED') {
        dataStatus = 'STOPPED';
      } else if (status === 'RUNNING' && !dataStatus) {
        dataStatus = 'RUNNING';
      }
    });

    return dataStatus;
  }

  refresh(): boolean {
    return false;
  }
}
```

