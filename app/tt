import anyio
from functools import wraps

def async_to_sync_safe(func):
    """
    Safely run async function from sync code using anyio, robust for production.
    """
    @wraps(func)
    def wrapper(*args, **kwargs):
        return anyio.run(func, *args, **kwargs)
    return wrapper


import asyncio
import concurrent.futures
from typing import Any, Coroutine

class AsyncRunner:
    @staticmethod
    def run(coroutine: Coroutine[Any, Any, Any]) -> Any:
        """
        Safely runs a coroutine from both sync and async contexts.
        If already in an event loop, it runs the coroutine in a separate thread
        to avoid blocking the loop, instead of using nest_asyncio.
        """
        try:
            loop = asyncio.get_running_loop()
            if loop.is_running():
                # Already in an event loop, so use a thread to run the coroutine
                with concurrent.futures.ThreadPoolExecutor() as executor:
                    future = executor.submit(lambda: asyncio.run(coroutine))
                    return future.result()
        except RuntimeError:
            # No event loop running, safe to call directly
            return asyncio.run(coroutine)
