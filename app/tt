import asyncio
import threading
from functools import wraps

_local = threading.local()

def async_to_sync_safe(func):
    """Wrapper qui réutilise la boucle existante ou en crée une nouvelle"""
    @wraps(func)
    def wrapper(*args, **kwargs):
        try:
            # Essayer de récupérer la boucle existante
            loop = asyncio.get_event_loop()
        except RuntimeError:
            # Si aucune boucle n'existe, en créer une nouvelle
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
        
        # Stocker dans le contexte thread-local
        _local.current_loop = loop
        
        if loop.is_running():
            # Si une boucle est déjà en cours, utiliser nest_asyncio
            import nest_asyncio
            nest_asyncio.apply(loop)
        
        return loop.run_until_complete(func(*args, **kwargs))
    return wrapper
