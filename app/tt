class AsyncRunner:
    @staticmethod
    def run(coroutine):
        """Run coroutine safely in both sync and async contexts"""
        try:
            loop = asyncio.get_running_loop()
            if loop.is_running():
                # Si dans un environnement async existant (Jupyter, etc.)
                import nest_asyncio
                nest_asyncio.apply()
                return loop.run_until_complete(coroutine)
        except RuntimeError:
            # Mode synchrone standard
            return asyncio.run(coroutine)
