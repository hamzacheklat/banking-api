class AsyncRunner:
    @staticmethod
    def run(coroutine: Coroutine[Any, Any, Any]) -> Any:
        """
        Run an async coroutine safely from sync or async context.
        Avoids `nest_asyncio` by executing in a background thread with its own event loop.
        """
        try:
            # If already in an event loop, offload to a thread
            asyncio.get_running_loop()
            result_container = {}

            def runner():
                try:
                    new_loop = asyncio.new_event_loop()
                    asyncio.set_event_loop(new_loop)
                    result = new_loop.run_until_complete(coroutine)
                    result_container['result'] = result
                finally:
                    new_loop.close()

            thread = threading.Thread(target=runner)
            thread.start()
            thread.join()
            return result_container['result']

        except RuntimeError:
            # No event loop running -> safe to call directly
            return asyncio.run(coroutine)
